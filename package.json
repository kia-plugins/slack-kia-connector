{
  "name": "slack-kia-connector",
  "version": "1.0.0",
  "description": "Slack connector for alpha-cent / KIAgent (paste-token, self-contained).",
  "license": "MIT",
  "private": false,
  "files": [
    "dist",
    "manifest.json"
  ],
  "scripts": {
    "build": "node build.mjs",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "pack": "npm run build && npm pack"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "better-sqlite3": "^11.0.0",
    "esbuild": "0.23.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.4.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "<rootDir>/src/**/__tests__/**/*.test.ts"
    ]
  }
}
